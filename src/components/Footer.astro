---
const year = new Date().getFullYear();

const links = [
  { href: "/blog", label: "Journal" },
  { href: "/portfolio", label: "Projects" },
  { href: "/podcast", label: "Podcast" },
  { href: "/about", label: "About" },
];
---

<footer class="border-t border-[var(--color-line)]">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-6 px-6 py-12 sm:flex-row sm:items-center sm:justify-between"
  >
    <div>
      <a
        href="/"
        class="text-base font-semibold tracking-[0.2em] text-[var(--color-ink)]"
      >
        AMESOMES
      </a>
      <p class="mt-1 text-sm text-[var(--color-muted)]">
        A digital lab for curious minds.
      </p>
    </div>

    <ul class="flex flex-wrap gap-x-6 gap-y-2">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm text-[var(--color-muted)] transition-colors hover:text-[var(--color-ink)]"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="border-t border-[var(--color-line)]">
    <div class="mx-auto max-w-6xl px-6 py-6">
      <p class="text-xs text-[var(--color-muted)]">
        &copy; {year} Amy &amp; Omar
      </p>
    </div>
  </div>
</footer>
