---
import ThemeToggle from "./ThemeToggle.astro";

const links = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Journal" },
  { href: "/portfolio", label: "Projects" },
  { href: "/podcast", label: "Podcast" },
  { href: "/about", label: "About" },
];

// Normalize current path so the active link highlights correctly.
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class="sticky top-0 z-50 border-b border-[var(--color-line)] bg-[var(--color-paper)]/80 backdrop-blur-md"
>
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <!-- Wordmark: typography IS the logo -->
    <a
      href="/"
      class="text-lg font-semibold tracking-[0.2em] text-[var(--color-ink)]"
    >
      AMESOMES
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => {
          const target = link.href.replace(/\/$/, "") || "/";
          const active = path === target;
          return (
            <li>
              <a
                href={link.href}
                class:list={[
                  "text-sm transition-colors hover:text-[var(--color-ink)]",
                  active
                    ? "text-[var(--color-ink)]"
                    : "text-[var(--color-muted)]",
                ]}
              >
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="flex items-center gap-2">
      <ThemeToggle />

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        type="button"
        aria-label="Toggle menu"
        aria-expanded="false"
        class="grid h-9 w-9 place-items-center rounded-full text-[var(--color-muted)] transition-colors hover:bg-[var(--color-surface)] hover:text-[var(--color-ink)] md:hidden"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-[var(--color-line)] px-6 py-4 md:hidden"
  >
    <ul class="flex flex-col gap-4">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-base text-[var(--color-muted)] transition-colors hover:text-[var(--color-ink)]"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script is:inline>
  (function () {
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    if (!toggle || !menu) return;
    toggle.addEventListener("click", function () {
      const open = menu.classList.toggle("hidden") === false;
      toggle.setAttribute("aria-expanded", String(open));
    });
  })();
</script>
