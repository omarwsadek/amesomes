---
import Layout from "../layouts/Layout.astro";

// Placeholder bios — edit these freely. Kept intentionally light so you
// and Amy can make them your own.
const people = [
  {
    name: "Amy",
    role: "Graphic designer & personal trainer",
    bio: "Graphic designer and personal trainer — and, objectively, the coolest person on Earth. Sharp eye, good heart.",
  },
  {
    name: "Omar",
    role: "Brain doctor & healthcare AI",
    bio: "Works in neuroscience and neurology, building AI for healthcare. I'm the mean one.",
  },
];
---

<Layout
  title="About — AmesOmes"
  description="Who's behind AmesOmes, and why a lab instead of a blog."
>
  <section class="mx-auto max-w-3xl px-6 pb-16 pt-20 sm:pt-28">
    <p class="mb-4 text-sm uppercase tracking-[0.35em] text-[var(--color-muted)]">
      About
    </p>
    <h1 class="font-serif text-5xl text-[var(--color-ink)] sm:text-6xl">
      Why AmesOmes?
    </h1>
    <div class="prose mt-8">
      <p>
        AmesOmes is a digital lab for curious minds — a place to think out
        loud, make things, and share the process. Not a portfolio, not a
        corporate site: a workshop with the door left open.
      </p>
      <p>
        It's where our writing, conversations, experiments, and projects live
        together, so ideas can bump into each other. We'd rather show the
        questions than pretend to have all the answers.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 pb-28">
    <h2 class="mb-8 text-sm uppercase tracking-[0.25em] text-[var(--color-muted)]">
      The two of us
    </h2>
    <div class="grid gap-px overflow-hidden rounded-2xl border border-[var(--color-line)] bg-[var(--color-line)] sm:grid-cols-2">
      {
        people.map((person) => (
          <div class="bg-[var(--color-paper)] p-8">
            <h3 class="font-serif text-3xl text-[var(--color-ink)]">
              {person.name}
            </h3>
            <p class="mt-1 text-xs uppercase tracking-[0.2em] text-[var(--color-muted)]">
              {person.role}
            </p>
            <p class="mt-4 leading-relaxed text-[var(--color-muted)]">
              {person.bio}
            </p>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
