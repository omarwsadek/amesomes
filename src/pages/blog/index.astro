---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import { readingTime } from "../../utils/readingTime";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout
  title="Journal — AmesOmes"
  description="Writing from Amy and Omar: essays, notes, and experiments from the lab."
>
  <section class="mx-auto max-w-4xl px-6 pb-28 pt-20 sm:pt-28">
    <header class="mb-14">
      <p class="mb-4 text-sm uppercase tracking-[0.35em] text-[var(--color-muted)]">
        Journal
      </p>
      <h1 class="font-serif text-5xl text-[var(--color-ink)] sm:text-6xl">
        Thinking out loud.
      </h1>
    </header>

    <ul class="flex flex-col">
      {
        posts.map((post) => (
          <li class="border-t border-[var(--color-line)]">
            <a
              href={`/blog/${post.id}/`}
              class="group flex flex-col gap-4 py-8 sm:flex-row sm:items-center sm:gap-8"
            >
              {post.data.heroImage && (
                <div class="w-full overflow-hidden rounded-xl sm:w-48 sm:shrink-0">
                  <img
                    src={post.data.heroImage}
                    alt=""
                    loading="lazy"
                    class="h-40 w-full object-cover transition-transform duration-500 group-hover:scale-105 sm:h-28"
                  />
                </div>
              )}
              <div class="flex-1">
                <div class="mb-2 flex items-center gap-3 text-xs uppercase tracking-[0.15em] text-[var(--color-muted)]">
                  <span>{post.data.category ?? "Journal"}</span>
                  <span aria-hidden="true">·</span>
                  <FormattedDate date={post.data.pubDate} />
                  <span aria-hidden="true">·</span>
                  <span>{readingTime(post.body)}</span>
                </div>
                <h2 class="text-2xl font-medium text-[var(--color-ink)]">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-[var(--color-muted)]">
                  {post.data.description}
                </p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>

    {
      posts.length === 0 && (
        <p class="text-[var(--color-muted)]">
          No entries yet. The first one is coming soon.
        </p>
      )
    }
  </section>
</Layout>
