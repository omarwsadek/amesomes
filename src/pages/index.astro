---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";

// Placeholder "latest" items. Swap these for real content in Session 2.
const latest = [
  {
    kind: "Journal",
    title: "Why we built a lab instead of a blog",
    excerpt:
      "Notes on curiosity, and why AmesOmes is a place to think out loud.",
    href: "/blog",
  },
  {
    kind: "Project",
    title: "Experiments in progress",
    excerpt: "A running gallery of things we are making and breaking.",
    href: "/portfolio",
  },
  {
    kind: "Podcast",
    title: "Conversations, soon",
    excerpt: "Long-form talks with people we find genuinely interesting.",
    href: "/podcast",
  },
];
---

<Layout title="AmesOmes — A digital lab for curious minds">
  <Hero />

  <!-- Latest content -->
  <section class="mx-auto max-w-6xl px-6 pb-28">
    <div
      class="mb-10 flex items-end justify-between border-b border-[var(--color-line)] pb-4"
    >
      <h2 class="text-sm uppercase tracking-[0.25em] text-[var(--color-muted)]">
        Latest
      </h2>
    </div>

    <div class="grid gap-px overflow-hidden rounded-2xl border border-[var(--color-line)] bg-[var(--color-line)] sm:grid-cols-3">
      {
        latest.map((item) => (
          <a
            href={item.href}
            class="group flex flex-col bg-[var(--color-paper)] p-8 transition-colors hover:bg-[var(--color-surface)]"
          >
            <span class="text-xs uppercase tracking-[0.2em] text-[var(--color-muted)]">
              {item.kind}
            </span>
            <h3 class="mt-4 text-xl font-medium text-[var(--color-ink)]">
              {item.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
              {item.excerpt}
            </p>
            <span class="mt-6 text-sm text-[var(--color-ink)] opacity-0 transition-opacity group-hover:opacity-100">
              Read &rarr;
            </span>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
