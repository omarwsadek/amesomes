---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Podcast — AmesOmes"
  description="Long-form conversations from Amy and Omar."
>
  <section class="mx-auto flex min-h-[60vh] max-w-3xl flex-col justify-center px-6 py-24">
    <p class="mb-4 text-sm uppercase tracking-[0.35em] text-[var(--color-muted)]">
      Podcast
    </p>
    <h1 class="font-serif text-5xl text-[var(--color-ink)] sm:text-6xl">
      Conversations, soon.
    </h1>
    <p class="mt-6 max-w-xl text-lg text-[var(--color-muted)]">
      Long-form talks with people we find genuinely interesting. Episodes will
      land here with Spotify players embedded. Stay curious.
    </p>
  </section>
</Layout>
