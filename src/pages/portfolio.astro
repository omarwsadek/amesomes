---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout
  title="Projects — AmesOmes"
  description="Creative projects and experiments from Amy and Omar."
>
  <section class="mx-auto max-w-5xl px-6 pb-28 pt-20 sm:pt-28">
    <header class="mb-14">
      <p class="mb-4 text-sm uppercase tracking-[0.35em] text-[var(--color-muted)]">
        Projects
      </p>
      <h1 class="font-serif text-5xl text-[var(--color-ink)] sm:text-6xl">
        Things we're making.
      </h1>
    </header>

    {
      projects.length === 0 ? (
        <p class="text-[var(--color-muted)]">
          No projects yet — this gallery is warming up.
        </p>
      ) : (
        <div class="grid gap-8 sm:grid-cols-2">
          {projects.map((project) => (
            <a
              href={`/portfolio/${project.id}/`}
              class="group flex flex-col overflow-hidden rounded-2xl border border-[var(--color-line)] transition-colors hover:bg-[var(--color-surface)]"
            >
              {project.data.heroImage && (
                <div class="aspect-[16/10] overflow-hidden">
                  <img
                    src={project.data.heroImage}
                    alt=""
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
              )}
              <div class="flex flex-1 flex-col p-6">
                <h2 class="text-xl font-medium text-[var(--color-ink)]">
                  {project.data.title}
                </h2>
                <p class="mt-2 flex-1 text-[var(--color-muted)]">
                  {project.data.description}
                </p>
                {project.data.tags && project.data.tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {project.data.tags.map((tag) => (
                      <span class="rounded-full border border-[var(--color-line)] px-3 py-1 text-xs uppercase tracking-[0.1em] text-[var(--color-muted)]">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      )
    }
  </section>
</Layout>
