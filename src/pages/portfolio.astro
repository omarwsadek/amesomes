---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Projects — AmesOmes"
  description="Creative projects and experiments from Amy and Omar."
>
  <section class="mx-auto flex min-h-[60vh] max-w-3xl flex-col justify-center px-6 py-24">
    <p class="mb-4 text-sm uppercase tracking-[0.35em] text-[var(--color-muted)]">
      Projects
    </p>
    <h1 class="font-serif text-5xl text-[var(--color-ink)] sm:text-6xl">
      A gallery in progress.
    </h1>
    <p class="mt-6 max-w-xl text-lg text-[var(--color-muted)]">
      Things we're making and breaking. This space will fill up soon — for
      now, wander through the <a
        href="/blog"
        class="text-[var(--color-ink)] underline underline-offset-4">Journal</a
      >.
    </p>
  </section>
</Layout>
